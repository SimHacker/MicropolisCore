{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Micropolis SvelteKit Server",
            "type": "pwa-node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": ["run", "dev"],
            "skipFiles": ["<node_internals>/**"],
            "console": "integratedTerminal",
            "env": {
                "NODE_ENV": "development"
            },
            "cwd": "${workspaceFolder}/apps/micropolis",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Local:.*http://localhost:(\\d+)",
                "uriFormat": "http://localhost:%s"
            },
            "outputCapture": "std"
        },
        {
            "name": "Launch VitaMooSpace Dev Server",
            "type": "pwa-node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": ["run", "dev"],
            "skipFiles": ["<node_internals>/**"],
            "console": "integratedTerminal",
            "env": {
                "NODE_ENV": "development"
            },
            "cwd": "${workspaceFolder}/apps/vitamoospace",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Local:.*http://localhost:(\\d+)",
                "uriFormat": "http://localhost:%s"
            },
            "outputCapture": "std"
        },
        {
            "name": "Attach SvelteKit Client to Chrome",
            "type": "pwa-chrome",
            "request": "attach",
            "port": 9222,
            "webRoot": "${workspaceFolder}/apps/micropolis/src",
            "pathMapping": {
                "/": "${webRoot}"
            }
        }
    ],
    "compounds": [
        {
            "name": "Debug Micropolis SvelteKit App",
            "configurations": [
                "Launch Micropolis SvelteKit Server",
                "Attach SvelteKit Client to Chrome"
            ],
            "stopAll": true
        }
    ]
}
