{
	"name": "micropolis",
	"version": "0.0.1",
	"scripts": {
		"dev": "concurrently -n vite,engine \"pnpm run dev:vite\" \"pnpm run dev:engine\"",
		"dev:vite": "vite dev",
		"dev:engine": "chokidar \"../../packages/micropolis-engine/src/*.cpp\" \"../../packages/micropolis-engine/src/*.h\" --initial --silent --command \"pnpm --filter @micropolis/engine-wasm run build\"",
		"prebuild": "pnpm --filter @micropolis/engine-wasm run build",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"micropolis": "tsx cli/entry.ts",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@fontsource/fira-mono": "^4.5.10",
		"@micropolis/engine-wasm": "workspace:*",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.4",
		"@types/webgl2": "^0.0.11",
		"@webgpu/types": "^0.1.42",
		"chokidar-cli": "^3.0.0",
		"concurrently": "^9.1.2",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"tsx": "^4.21.0",
		"typescript": "^5.0.0",
		"vite": "^5.0.3",
		"vitest": "^2.1.9",
		"yargs": "^17.7.2"
	},
	"type": "module",
	"dependencies": {
		"@micropolis/render-core": "workspace:*",
		"@micropolis/tile-renderer": "workspace:*",
		"gray-matter": "^4.0.3",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-heading-id": "^1.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unified": "^11.0.5",
		"vite-plugin-static-copy": "^1.0.5",
		"vite-plugin-top-level-await": "^1.4.1",
		"yaml": "^2.8.4"
	}
}
