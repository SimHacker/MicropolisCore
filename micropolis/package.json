{
	"name": "micropolis",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev",
		"build:jekyll": "cd website && bundle exec jekyll build --config _config.yml,_config_headless.yml --destination ../_jekyll_content_build",
		"build:svelte": "mkdir -p build ; vite build",
		"build": "npm run build:jekyll && npm run build:svelte",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"micropolis": "tsx cli/entry.ts",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@fontsource/fira-mono": "^4.5.10",
		"@neoconfetti/svelte": "^1.0.0",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.4",
		"@types/webgl2": "^0.0.11",
		"@webgpu/types": "^0.1.42",
		"chalk": "^4.1.2",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"tslib": "^2.4.1",
		"tsx": "^4.21.0",
		"typescript": "^5.0.0",
		"vite": "^5.0.3",
		"vitest": "^2.1.9",
		"yargs": "^17.7.2"
	},
	"type": "module",
	"dependencies": {
		"@capacitor/android": "^6.1.0",
		"@capacitor/cli": "^6.1.0",
		"@capacitor/core": "^6.1.0",
		"@capacitor/ios": "^6.1.0",
		"@esbuild-plugins/node-globals-polyfill": "^0.2.3",
		"@esbuild-plugins/node-modules-polyfill": "^0.2.2",
		"rollup-plugin-node-builtins": "^2.1.2",
		"rollup-plugin-node-globals": "^1.4.0",
		"svelte-gestures": "^5.0.1",
		"vite-plugin-node-polyfills": "^0.22.0",
		"vite-plugin-static-copy": "^1.0.5",
		"vite-plugin-top-level-await": "^1.4.1",
		"vite-plugin-wasm": "^3.3.0",
		"yaml": "^2.8.4"
	}
}
